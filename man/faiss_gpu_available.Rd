\name{faiss_gpu_available}
\alias{faiss_gpu_available}
\title{Check whether FAISS GPU support is available}
\usage{
faiss_gpu_available()
}
\value{
\code{TRUE} when faissR was compiled and linked against a FAISS build
that reports GPU support.
}
\description{
Check whether FAISS GPU support is available.
}
\examples{
faiss_gpu_available()
}
