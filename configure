#!/bin/sh

set -eu

use_cuda=${FAISSR_USE_CUDA:-}
if [ -z "$use_cuda" ]; then use_cuda=auto; fi
cuda_home=${CUDA_HOME:-}
nvcc=${NVCC:-}
if [ -z "$nvcc" ]; then
  if [ -n "$cuda_home" ] && [ -x "$cuda_home/bin/nvcc" ]; then
    nvcc="$cuda_home/bin/nvcc"
  else
    nvcc=$(command -v nvcc 2>/dev/null || true)
  fi
fi

if [ -z "$cuda_home" ] && [ -n "$nvcc" ]; then
  cuda_bin=$(dirname "$nvcc")
  cuda_home=$(dirname "$cuda_bin")
fi

if [ "$use_cuda" = "1" ] && [ -z "$nvcc" ]; then
  echo "FAISSR_USE_CUDA=1 was requested, but nvcc was not found." >&2
  echo "Set CUDA_HOME or NVCC, or use FAISSR_USE_CUDA=0 for a non-CUDA build." >&2
  exit 1
fi

if [ "$use_cuda" = "1" ] && [ -z "$cuda_home" ]; then
  echo "FAISSR_USE_CUDA=1 was requested, but CUDA_HOME could not be resolved." >&2
  echo "Set CUDA_HOME to the CUDA toolkit root." >&2
  exit 1
fi

cppflags=""
libs="-pthread"

faiss_home=${FAISS_HOME:-}
faiss_objects="nn_faiss_bridge.o nn_faiss_impl.o"
faiss_cppflags=""
faiss_libs=""
faiss_libdir=""

if [ -n "$faiss_home" ] && [ -f "$faiss_home/include/faiss/IndexFlat.h" ]; then
  faiss_cppflags="-I$faiss_home/include"
  if [ -d "$faiss_home/lib64" ]; then
    faiss_libdir="$faiss_home/lib64"
  else
    faiss_libdir="$faiss_home/lib"
  fi
  faiss_libs="-L$faiss_libdir -Wl,-rpath,$faiss_libdir -lfaiss"
elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists faiss 2>/dev/null; then
  faiss_cppflags=$(pkg-config --cflags faiss)
  faiss_libs=$(pkg-config --libs faiss)
elif [ -f /opt/homebrew/include/faiss/IndexFlat.h ] && \
     { [ -f /opt/homebrew/lib/libfaiss.dylib ] || [ -f /opt/homebrew/lib/libfaiss.a ]; }; then
  faiss_cppflags="-I/opt/homebrew/include"
  faiss_libdir="/opt/homebrew/lib"
  faiss_libs="-L$faiss_libdir -Wl,-rpath,$faiss_libdir -lfaiss"
elif [ -f /usr/local/include/faiss/IndexFlat.h ] && \
     { [ -f /usr/local/lib/libfaiss.dylib ] || [ -f /usr/local/lib/libfaiss.so ] || [ -f /usr/local/lib/libfaiss.a ]; }; then
  faiss_cppflags="-I/usr/local/include"
  faiss_libdir="/usr/local/lib"
  faiss_libs="-L$faiss_libdir -Wl,-rpath,$faiss_libdir -lfaiss"
fi

if [ -z "$faiss_cppflags" ] || [ -z "$faiss_libs" ]; then
  echo "FAISS is required to build faissR, but FAISS headers/library were not found." >&2
  echo "Install FAISS or set FAISS_HOME to a prefix containing include/faiss and lib/libfaiss." >&2
  echo "CUDA/cuVS is optional; NVIDIA libraries are not required for a CPU-only FAISS build." >&2
  exit 1
fi

cppflags="$cppflags -DFAISSR_HAS_FAISS $faiss_cppflags"
libs="$libs $faiss_libs"

cuda_objects="nn_cuda_stub.o"
cuda_rule=""
if [ "$use_cuda" != "0" ] && [ -n "$nvcc" ] && [ -n "$cuda_home" ]; then
  cuda_arch_flags=""
  for arch in ${FAISSR_CUDA_ARCH:-}; do
    cuda_arch_flags="$cuda_arch_flags -gencode=arch=compute_$arch,code=sm_$arch"
  done
  cuda_extra_flags=${FAISSR_CUDA_FLAGS:-}
  cuda_objects="nn_cuda_impl.o nn_cuda_kernels.o"
  cppflags="$cppflags -DFAISSR_HAS_CUDA -I$cuda_home/include"
  libs="$libs -L$cuda_home/lib64 -L$cuda_home/lib -lcudart"
  cuda_rule="
.DEFAULT_GOAL := all

CUDA_NVCCFLAGS = -std=c++14 -x cu -Xcompiler -fPIC$cuda_arch_flags $cuda_extra_flags

nn_cuda_kernels.o: nn_cuda_kernels.cpp
	\$(NVCC) \$(CUDA_NVCCFLAGS) -c \$< -o \$@
"
fi

use_cugraph=${FAISSR_USE_CUGRAPH:-}
if [ -z "$use_cugraph" ]; then use_cugraph=auto; fi
cugraph_home=${CUGRAPH_HOME:-}
cugraph_objects="graph_cugraph_stub.o"
cugraph_cppflags=""
cugraph_libs=""

if [ "$use_cugraph" != "0" ]; then
  if [ "$cuda_objects" = "nn_cuda_stub.o" ]; then
    if [ "$use_cugraph" = "1" ]; then
      echo "FAISSR_USE_CUGRAPH=1 was requested, but faissR is not being built with CUDA." >&2
      echo "Set FAISSR_USE_CUDA=1 and CUDA_HOME/NVCC, or use FAISSR_USE_CUGRAPH=0." >&2
      exit 1
    fi
  else
    if [ -z "$cugraph_home" ] && [ -n "${CONDA_PREFIX:-}" ] && \
       [ -f "$CONDA_PREFIX/include/cugraph_c/community_algorithms.h" ]; then
      cugraph_home=$CONDA_PREFIX
    fi
    if [ -n "$cugraph_home" ] && [ -f "$cugraph_home/include/cugraph_c/community_algorithms.h" ]; then
      cugraph_cppflags="-I$cugraph_home/include"
      if [ -d "$cugraph_home/lib64" ]; then
        cugraph_libdir="$cugraph_home/lib64"
      else
        cugraph_libdir="$cugraph_home/lib"
      fi
      cugraph_libs="-L$cugraph_libdir -Wl,-rpath,$cugraph_libdir -lcugraph_c -lcugraph"
      if [ -f "$cugraph_libdir/libraft.so" ]; then
        cugraph_libs="$cugraph_libs -lraft"
      fi
    elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists libcugraph 2>/dev/null; then
      cugraph_cppflags=$(pkg-config --cflags libcugraph)
      cugraph_libs=$(pkg-config --libs libcugraph)
    elif [ -f /usr/local/include/cugraph_c/community_algorithms.h ] && \
         { [ -f /usr/local/lib/libcugraph_c.so ] || [ -f /usr/local/lib/libcugraph_c.a ]; }; then
      cugraph_cppflags="-I/usr/local/include"
      cugraph_libs="-L/usr/local/lib -Wl,-rpath,/usr/local/lib -lcugraph_c -lcugraph"
    fi

    if [ -n "$cugraph_cppflags" ] && [ -n "$cugraph_libs" ]; then
      cugraph_objects="graph_cugraph_impl.o"
      cppflags="$cppflags -DFAISSR_HAS_CUGRAPH $cugraph_cppflags"
      libs="$libs $cugraph_libs"
    elif [ "$use_cugraph" = "1" ]; then
      echo "FAISSR_USE_CUGRAPH=1 was requested, but RAPIDS libcugraph headers/library were not found." >&2
      echo "Set CUGRAPH_HOME to a prefix containing include/cugraph_c and lib/libcugraph_c, or install a pkg-config libcugraph file." >&2
      exit 1
    fi
  fi
fi

use_cuvs=${FAISSR_USE_CUVS:-}
if [ -z "$use_cuvs" ]; then use_cuvs=auto; fi
cuvs_home=${CUVS_HOME:-}
cuvs_objects="nn_cuvs_bridge.o nn_cuvs_stub.o"
cuvs_cppflags=""
cuvs_libs=""

append_cuvs_include_dir() {
  if [ -d "$1" ]; then
    cuvs_cppflags="$cuvs_cppflags -I$1"
  fi
}

append_cuvs_lib_dir() {
  if [ -d "$1" ]; then
    cuvs_libs="$cuvs_libs -L$1 -Wl,-rpath,$1"
  fi
}

if [ "$use_cuvs" != "0" ]; then
  if [ "$cuda_objects" = "nn_cuda_stub.o" ]; then
    if [ "$use_cuvs" = "1" ]; then
      echo "FAISSR_USE_CUVS=1 was requested, but faissR is not being built with CUDA." >&2
      echo "Set FAISSR_USE_CUDA=1 and CUDA_HOME/NVCC, or use FAISSR_USE_CUVS=0." >&2
      exit 1
    fi
  else
    if [ -z "$cuvs_home" ] && [ -n "${CONDA_PREFIX:-}" ] && \
       [ -f "$CONDA_PREFIX/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_home=$CONDA_PREFIX
    fi

    if [ -n "$cuvs_home" ] && [ ! -f "$cuvs_home/include/cuvs/neighbors/cagra.h" ] && \
       [ -f "$cuvs_home/libcuvs/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_home="$cuvs_home/libcuvs"
    fi

    if [ -n "$cuvs_home" ] && [ -f "$cuvs_home/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_cppflags="-I. -I$cuvs_home/include"
      cuvs_parent=$(dirname "$cuvs_home")
      append_cuvs_include_dir "$cuvs_parent/libraft/include"
      append_cuvs_include_dir "$cuvs_parent/librmm/include"
      if [ -d "$cuvs_home/lib64" ]; then
        append_cuvs_lib_dir "$cuvs_home/lib64"
      else
        append_cuvs_lib_dir "$cuvs_home/lib"
      fi
      append_cuvs_lib_dir "$cuvs_parent/libraft/lib64"
      append_cuvs_lib_dir "$cuvs_parent/libraft/lib"
      append_cuvs_lib_dir "$cuvs_parent/librmm/lib64"
      append_cuvs_lib_dir "$cuvs_parent/librmm/lib"
      for cuvs_component_lib in "$cuvs_parent"/*/lib64 "$cuvs_parent"/*/lib; do
        append_cuvs_lib_dir "$cuvs_component_lib"
      done
      if [ -d "$cuvs_parent/nvidia" ]; then
        for cuvs_dep_lib in "$cuvs_parent"/nvidia/*/lib; do
          append_cuvs_lib_dir "$cuvs_dep_lib"
        done
      fi
      if [ -f "$cuvs_home/lib64/libcuvs_c.so" ] || \
         [ -f "$cuvs_home/lib/libcuvs_c.so" ]; then
        cuvs_libs="$cuvs_libs -lcuvs_c"
      fi
      cuvs_libs="$cuvs_libs -lcuvs"
      if [ -f "$cuvs_parent/libraft/lib64/libraft.so" ] || \
         [ -f "$cuvs_parent/libraft/lib/libraft.so" ]; then
        cuvs_libs="$cuvs_libs -lraft"
      fi
      if [ -f "$cuvs_parent/librmm/lib64/librmm.so" ] || \
         [ -f "$cuvs_parent/librmm/lib/librmm.so" ]; then
        cuvs_libs="$cuvs_libs -lrmm"
      fi
      if [ -f "$cuvs_parent/rapids_logger/lib64/librapids_logger.so" ] || \
         [ -f "$cuvs_parent/rapids_logger/lib/librapids_logger.so" ]; then
        cuvs_libs="$cuvs_libs -lrapids_logger"
      fi
    elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists cuvs 2>/dev/null; then
      cuvs_cppflags=$(pkg-config --cflags cuvs)
      cuvs_libs=$(pkg-config --libs cuvs)
    elif [ -f /usr/local/include/cuvs/neighbors/cagra.h ] && \
         { [ -f /usr/local/lib/libcuvs.so ] || [ -f /usr/local/lib/libcuvs.a ]; }; then
      cuvs_cppflags="-I/usr/local/include"
      cuvs_libs="-L/usr/local/lib -Wl,-rpath,/usr/local/lib -lcuvs"
    fi

    if [ -n "$cuvs_cppflags" ] && [ -n "$cuvs_libs" ]; then
      cuvs_objects="nn_cuvs_bridge.o nn_cuvs_impl.o"
      cppflags="$cppflags -DFAISSR_HAS_CUVS $cuvs_cppflags"
      libs="$libs $cuvs_libs"
    elif [ "$use_cuvs" = "1" ]; then
      echo "FAISSR_USE_CUVS=1 was requested, but RAPIDS cuVS headers/library were not found." >&2
      echo "Set CUVS_HOME to a prefix containing include/cuvs and lib/libcuvs, or install a pkg-config cuvs file." >&2
      exit 1
    fi
  fi
fi

{
  echo "CXX_STD = CXX20"
  echo 'PKG_CXXFLAGS = -pthread $(SHLIB_OPENMP_CXXFLAGS)'
  if [ -n "$cppflags" ]; then
    echo "PKG_CPPFLAGS = $cppflags"
  fi
  printf '%s%s\n' 'PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) ' "$libs"
  if [ "$cuda_objects" != "nn_cuda_stub.o" ]; then
    echo "NVCC = $nvcc"
    printf "%s" "$cuda_rule"
  fi
  echo "OBJECTS = RcppExports.o embedding_utils.o graph.o $cugraph_objects nn.o nn_auto_select.o nn_fortran.o $faiss_objects $cuvs_objects nn_cuda_bridge.o $cuda_objects"
} > src/Makevars
