#!/bin/sh

set -eu

wasm_build=0
for arg in "$@"; do
  case "$arg" in
    --host=wasm32-*|--host=*emscripten*)
      wasm_build=1
      ;;
  esac
done

write_diagnostic_makevars() {
  diagnostic_cppflags=$1
  {
    echo "CXX_STD = CXX20"
    echo "PKG_CXXFLAGS ="
    echo "PKG_CPPFLAGS = $diagnostic_cppflags"
    echo "PKG_LIBS ="
    echo "OBJECTS = RcppExports.o embedding_utils.o nn.o nn_metal_grid_stub.o nn_auto_select.o nn_fortran.o nn_faiss_bridge.o nn_faiss_stub.o nn_cuvs_bridge.o nn_cuvs_stub.o nn_cuda_bridge.o nn_cuda_stub.o"
  } > src/Makevars
}

if [ "$wasm_build" = "1" ]; then
  echo "WebAssembly target detected: building faissR with diagnostic stubs." >&2
  echo "Native FAISS/CUDA/cuVS libraries are not available for webR/WebAssembly;" >&2
  echo "native Linux/macOS builds still require FAISS." >&2
  write_diagnostic_makevars "-DFAISSR_WASM_UNSUPPORTED"
  exit 0
fi

use_cuda=${FAISSR_USE_CUDA:-}
if [ -z "$use_cuda" ]; then use_cuda=auto; fi
if [ "${FAISSR_REQUIRE_CUDA:-0}" = "1" ]; then use_cuda=1; fi
cuda_home=${CUDA_HOME:-}
nvcc=${NVCC:-}
if [ -z "$nvcc" ]; then
  if [ -n "$cuda_home" ] && [ -x "$cuda_home/bin/nvcc" ]; then
    nvcc="$cuda_home/bin/nvcc"
  else
    nvcc=$(command -v nvcc 2>/dev/null || true)
  fi
fi

if [ -z "$cuda_home" ] && [ -n "$nvcc" ]; then
  cuda_bin=$(dirname "$nvcc")
  cuda_home=$(dirname "$cuda_bin")
fi

if [ "$use_cuda" = "1" ] && [ -z "$nvcc" ]; then
  echo "A CUDA build was requested (FAISSR_USE_CUDA=1 or FAISSR_REQUIRE_CUDA=1), but nvcc was not found." >&2
  echo "Set CUDA_HOME or NVCC, or use FAISSR_USE_CUDA=0 for a non-CUDA build." >&2
  exit 1
fi

if [ "$use_cuda" = "1" ] && [ -z "$cuda_home" ]; then
  echo "A CUDA build was requested (FAISSR_USE_CUDA=1 or FAISSR_REQUIRE_CUDA=1), but CUDA_HOME could not be resolved." >&2
  echo "Set CUDA_HOME to the CUDA toolkit root." >&2
  exit 1
fi

cppflags=""
libs="-pthread"
extra_cxxflags=""
nn_metal_grid_objects="nn_metal_grid_stub.o"
if [ "$(uname -s 2>/dev/null || echo unknown)" = "Darwin" ]; then
  nn_metal_grid_objects="nn_metal_grid_impl.o"
  cppflags="$cppflags -DFAISSR_HAS_METAL"
  libs="$libs -framework Foundation -framework Metal"
fi

faiss_home=${FAISS_HOME:-}
faiss_objects="nn_faiss_bridge.o nn_faiss_impl.o"
faiss_cppflags=""
faiss_libs=""
faiss_libdir=""
libomp_home=${LIBOMP_HOME:-${FAISSR_LIBOMP_HOME:-}}
libomp_cppflags=""
libomp_libs=""
brew_cmd=""

find_brew() {
  if [ -n "${BREW:-}" ] && [ -x "${BREW:-}" ]; then
    brew_cmd=$BREW
    return 0
  fi
  candidate_brew=$(command -v brew 2>/dev/null || true)
  if [ -n "$candidate_brew" ] && [ -x "$candidate_brew" ]; then
    brew_cmd=$candidate_brew
    return 0
  fi
  for candidate_brew in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$candidate_brew" ]; then
      brew_cmd=$candidate_brew
      return 0
    fi
  done
  return 1
}

macos_auto_install_faiss() {
  if [ "$(uname -s 2>/dev/null || echo unknown)" != "Darwin" ]; then
    return 1
  fi
  if [ "${FAISSR_AUTO_INSTALL_FAISS:-}" = "1" ]; then
    return 0
  fi
  if [ -n "${FAISSR_AUTO_INSTALL_FAISS:-}" ]; then
    return 1
  fi
  if [ "${GITHUB_ACTIONS:-}" = "true" ] || \
     [ "${CI:-}" = "true" ] || \
     [ -n "${RUNNER_OS:-}" ] || \
     [ -n "${UNIVERSE_NAME:-}" ] || \
     [ -n "${MY_UNIVERSE:-}" ]; then
    return 0
  fi
  return 1
}

runiverse_macos_diagnostic_stubs_allowed() {
  if [ "$(uname -s 2>/dev/null || echo unknown)" != "Darwin" ]; then
    return 1
  fi
  if [ "${FAISSR_RUNIVERSE_MACOS_STUBS:-1}" = "0" ]; then
    return 1
  fi
  if [ -n "${UNIVERSE_NAME:-}" ] || [ -n "${MY_UNIVERSE:-}" ]; then
    return 0
  fi
  return 1
}

try_libomp_prefix() {
  libomp_prefix=$1
  if [ -n "$libomp_prefix" ] && [ -f "$libomp_prefix/include/omp.h" ]; then
    if [ -d "$libomp_prefix/lib64" ]; then
      candidate_libomp_libdir="$libomp_prefix/lib64"
    else
      candidate_libomp_libdir="$libomp_prefix/lib"
    fi
    candidate_libomp_file=""
    if [ -f "$candidate_libomp_libdir/libomp.dylib" ]; then
      candidate_libomp_file="$candidate_libomp_libdir/libomp.dylib"
    elif [ -f "$candidate_libomp_libdir/libomp.so" ]; then
      candidate_libomp_file="$candidate_libomp_libdir/libomp.so"
    elif [ -f "$candidate_libomp_libdir/libomp.a" ]; then
      candidate_libomp_file="$candidate_libomp_libdir/libomp.a"
    fi
    if [ -n "$candidate_libomp_file" ]; then
      libomp_cppflags="-I$libomp_prefix/include"
      libomp_libs="-Wl,-rpath,$candidate_libomp_libdir $candidate_libomp_file"
      return 0
    fi
  fi
  return 1
}

try_homebrew_libomp() {
  if find_brew; then
    brew_libomp_prefix=$("$brew_cmd" --prefix libomp 2>/dev/null || true)
    if try_libomp_prefix "$brew_libomp_prefix"; then
      return 0
    fi
    brew_prefix=$("$brew_cmd" --prefix 2>/dev/null || true)
    if try_libomp_prefix "$brew_prefix/opt/libomp"; then
      return 0
    fi
  fi
  return 1
}

try_faiss_prefix() {
  faiss_prefix=$1
  if [ -n "$faiss_prefix" ] && [ -f "$faiss_prefix/include/faiss/IndexFlat.h" ]; then
    if [ -d "$faiss_prefix/lib64" ]; then
      candidate_faiss_libdir="$faiss_prefix/lib64"
    else
      candidate_faiss_libdir="$faiss_prefix/lib"
    fi
    if [ -f "$candidate_faiss_libdir/libfaiss.dylib" ] || \
       [ -f "$candidate_faiss_libdir/libfaiss.so" ] || \
       [ -f "$candidate_faiss_libdir/libfaiss.a" ]; then
      faiss_cppflags="-I$faiss_prefix/include"
      faiss_libdir="$candidate_faiss_libdir"
      faiss_libs="-L$faiss_libdir -Wl,-rpath,$faiss_libdir -lfaiss"
      return 0
    fi
  fi
  return 1
}

try_faiss_system() {
  if [ -f /usr/include/faiss/IndexFlat.h ]; then
    for candidate_faiss_libdir in /usr/lib /usr/lib/* /lib /lib/*; do
      if [ -f "$candidate_faiss_libdir/libfaiss.so" ] || \
         [ -f "$candidate_faiss_libdir/libfaiss.a" ]; then
        faiss_cppflags="-I/usr/include"
        faiss_libdir="$candidate_faiss_libdir"
        faiss_libs="-L$faiss_libdir -Wl,-rpath,$faiss_libdir -lfaiss"
        return 0
      fi
    done
  fi
  return 1
}

try_homebrew_faiss() {
  if find_brew; then
    brew_faiss_prefix=$("$brew_cmd" --prefix faiss 2>/dev/null || true)
    if try_faiss_prefix "$brew_faiss_prefix"; then
      return 0
    fi
    brew_prefix=$("$brew_cmd" --prefix 2>/dev/null || true)
    if try_faiss_prefix "$brew_prefix/opt/faiss"; then
      return 0
    fi
  fi
  return 1
}

if try_faiss_prefix "$faiss_home"; then
  :
elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists faiss 2>/dev/null; then
  faiss_cppflags=$(pkg-config --cflags faiss)
  faiss_libs=$(pkg-config --libs faiss)
elif [ -n "${CONDA_PREFIX:-}" ] && try_faiss_prefix "$CONDA_PREFIX"; then
  :
elif try_faiss_prefix /opt/homebrew; then
  :
elif try_faiss_prefix /usr/local; then
  :
elif try_faiss_system; then
  :
elif try_homebrew_faiss; then
  :
fi

if [ -z "$faiss_cppflags" ] || [ -z "$faiss_libs" ]; then
  if macos_auto_install_faiss; then
    if [ "$(uname -s 2>/dev/null || echo unknown)" = "Darwin" ] && \
       find_brew; then
      if [ "${FAISSR_AUTO_INSTALL_FAISS:-}" = "1" ]; then
        echo "FAISSR_AUTO_INSTALL_FAISS=1: installing FAISS and libomp with Homebrew." >&2
      else
        echo "macOS CI detected: installing mandatory FAISS and OpenMP runtime with Homebrew." >&2
      fi
      "$brew_cmd" install faiss libomp
      if ! try_homebrew_faiss; then
        echo "Homebrew FAISS installation finished, but configure still could not find include/faiss and lib/libfaiss." >&2
      fi
    else
      if ! runiverse_macos_diagnostic_stubs_allowed; then
        echo "Automatic FAISS installation was requested, but it is supported only on macOS with Homebrew." >&2
      fi
    fi
  fi
fi

if [ -z "$faiss_cppflags" ] || [ -z "$faiss_libs" ]; then
  if runiverse_macos_diagnostic_stubs_allowed; then
    echo "r-universe/BiocStaging macOS binary worker detected without FAISS." >&2
    echo "Building diagnostic stubs because this worker removes Homebrew and does not provide FAISS." >&2
    echo "Linux and user macOS source builds still require real FAISS." >&2
    write_diagnostic_makevars "-DFAISSR_MACOS_CI_NO_FAISS"
    exit 0
  fi
  echo "FAISS is required to build faissR, but FAISS headers/library were not found." >&2
  if [ "$(uname -s 2>/dev/null || echo unknown)" = "Darwin" ]; then
    echo "On macOS with Homebrew, install FAISS and OpenMP with:" >&2
    echo "  brew install faiss libomp" >&2
    echo "Then retry, or set FAISS_HOME=\"\$(brew --prefix faiss)\" before installing faissR." >&2
    echo "For an explicit GitHub-install convenience path, run:" >&2
    echo "  Sys.setenv(FAISSR_AUTO_INSTALL_FAISS = \"1\")" >&2
    echo "  remotes::install_github(\"tkcaccia/faissR\")" >&2
  else
    echo "Install FAISS or set FAISS_HOME to a prefix containing include/faiss and lib/libfaiss." >&2
  fi
  echo "NVIDIA CUDA/cuVS libraries are not required for a CPU-only FAISS build." >&2
  echo "For a NVIDIA GPU build, set FAISSR_REQUIRE_CUDA=1 and, if needed, FAISSR_REQUIRE_CUVS=1 so missing GPU libraries are fatal." >&2
  exit 1
fi

if [ "$(uname -s 2>/dev/null || echo unknown)" = "Darwin" ]; then
  if try_libomp_prefix "$libomp_home"; then
    :
  elif [ -n "${CONDA_PREFIX:-}" ] && try_libomp_prefix "$CONDA_PREFIX"; then
    :
  elif try_homebrew_libomp; then
    :
  elif try_libomp_prefix /opt/homebrew/opt/libomp; then
    :
  elif try_libomp_prefix /usr/local/opt/libomp; then
    :
  elif try_libomp_prefix /opt/homebrew; then
    :
  elif try_libomp_prefix /usr/local; then
    :
  fi

  if [ -z "$libomp_cppflags" ] || [ -z "$libomp_libs" ]; then
    if macos_auto_install_faiss && find_brew; then
      if [ "${FAISSR_AUTO_INSTALL_FAISS:-}" = "1" ]; then
        echo "FAISSR_AUTO_INSTALL_FAISS=1: installing libomp with Homebrew." >&2
      else
        echo "macOS CI detected: installing OpenMP runtime with Homebrew." >&2
      fi
      "$brew_cmd" install libomp
      try_homebrew_libomp || true
    fi
  fi

  if [ -z "$libomp_cppflags" ] || [ -z "$libomp_libs" ]; then
    echo "FAISS was found, but macOS OpenMP headers/library were not found." >&2
    echo "Homebrew FAISS headers include <omp.h>, so Apple clang needs Homebrew libomp." >&2
    echo "Install it with:" >&2
    echo "  brew install libomp" >&2
    echo "Then retry, or set LIBOMP_HOME=\"\$(brew --prefix libomp)\" before installing faissR." >&2
    echo "For an explicit GitHub-install convenience path, run:" >&2
    echo "  Sys.setenv(FAISSR_AUTO_INSTALL_FAISS = \"1\")" >&2
    echo "  remotes::install_github(\"tkcaccia/faissR\")" >&2
    exit 1
  fi

  extra_cxxflags="$extra_cxxflags -Xpreprocessor -fopenmp"
fi

cppflags="$cppflags -DFAISSR_HAS_FAISS $faiss_cppflags $libomp_cppflags"
libs="$libs $faiss_libs $libomp_libs"

cuda_objects="nn_cuda_stub.o"
cuda_rule=""
if [ "$use_cuda" != "0" ] && [ -n "$nvcc" ] && [ -n "$cuda_home" ]; then
  cuda_arch_flags=""
  for arch in ${FAISSR_CUDA_ARCH:-}; do
    cuda_arch_flags="$cuda_arch_flags -gencode=arch=compute_$arch,code=sm_$arch"
  done
  cuda_extra_flags=${FAISSR_CUDA_FLAGS:-}
  cuda_objects="nn_cuda_impl.o nn_cuda_kernels.o"
  cppflags="$cppflags -DFAISSR_HAS_CUDA -I$cuda_home/include"
  libs="$libs -L$cuda_home/lib64 -L$cuda_home/lib -lcudart"
  cuda_rule="
.DEFAULT_GOAL := all

CUDA_NVCCFLAGS = -std=c++17 -x cu -Xcompiler -fPIC$cuda_arch_flags $cuda_extra_flags

nn_cuda_kernels.o: nn_cuda_kernels.cpp
	\$(NVCC) \$(CUDA_NVCCFLAGS) -c \$< -o \$@
"
fi

use_cuvs=${FAISSR_USE_CUVS:-}
if [ -z "$use_cuvs" ]; then use_cuvs=auto; fi
if [ "${FAISSR_REQUIRE_CUVS:-0}" = "1" ]; then use_cuvs=1; fi
cuvs_home=${CUVS_HOME:-}
cuvs_objects="nn_cuvs_bridge.o nn_cuvs_stub.o"
cuvs_cppflags=""
cuvs_libs=""

append_cuvs_include_dir() {
  if [ -d "$1" ]; then
    cuvs_cppflags="$cuvs_cppflags -I$1"
  fi
}

append_cuvs_lib_dir() {
  if [ -d "$1" ]; then
    cuvs_libs="$cuvs_libs -L$1 -Wl,-rpath,$1"
  fi
}

if [ "$use_cuvs" != "0" ]; then
  if [ "$cuda_objects" = "nn_cuda_stub.o" ]; then
    if [ "$use_cuvs" = "1" ]; then
      echo "cuVS was requested (FAISSR_USE_CUVS=1 or FAISSR_REQUIRE_CUVS=1), but faissR is not being built with CUDA." >&2
      echo "Set FAISSR_USE_CUDA=1 and CUDA_HOME/NVCC, or use FAISSR_USE_CUVS=0." >&2
      exit 1
    fi
  else
    if [ -z "$cuvs_home" ] && [ -n "${CONDA_PREFIX:-}" ] && \
       [ -f "$CONDA_PREFIX/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_home=$CONDA_PREFIX
    fi

    if [ -n "$cuvs_home" ] && [ ! -f "$cuvs_home/include/cuvs/neighbors/cagra.h" ] && \
       [ -f "$cuvs_home/libcuvs/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_home="$cuvs_home/libcuvs"
    fi

    if [ -n "$cuvs_home" ] && [ -f "$cuvs_home/include/cuvs/neighbors/cagra.h" ]; then
      cuvs_cppflags="-I. -I$cuvs_home/include"
      cuvs_parent=$(dirname "$cuvs_home")
      append_cuvs_include_dir "$cuvs_parent/libraft/include"
      append_cuvs_include_dir "$cuvs_parent/librmm/include"
      if [ -d "$cuvs_home/lib64" ]; then
        append_cuvs_lib_dir "$cuvs_home/lib64"
      else
        append_cuvs_lib_dir "$cuvs_home/lib"
      fi
      append_cuvs_lib_dir "$cuvs_parent/libraft/lib64"
      append_cuvs_lib_dir "$cuvs_parent/libraft/lib"
      append_cuvs_lib_dir "$cuvs_parent/librmm/lib64"
      append_cuvs_lib_dir "$cuvs_parent/librmm/lib"
      for cuvs_component_lib in "$cuvs_parent"/*/lib64 "$cuvs_parent"/*/lib; do
        append_cuvs_lib_dir "$cuvs_component_lib"
      done
      if [ -d "$cuvs_parent/nvidia" ]; then
        for cuvs_dep_lib in "$cuvs_parent"/nvidia/*/lib; do
          append_cuvs_lib_dir "$cuvs_dep_lib"
        done
      fi
      if [ -f "$cuvs_home/lib64/libcuvs_c.so" ] || \
         [ -f "$cuvs_home/lib/libcuvs_c.so" ]; then
        cuvs_libs="$cuvs_libs -lcuvs_c"
      fi
      cuvs_libs="$cuvs_libs -lcuvs"
      if [ -f "$cuvs_parent/libraft/lib64/libraft.so" ] || \
         [ -f "$cuvs_parent/libraft/lib/libraft.so" ]; then
        cuvs_libs="$cuvs_libs -lraft"
      fi
      if [ -f "$cuvs_parent/librmm/lib64/librmm.so" ] || \
         [ -f "$cuvs_parent/librmm/lib/librmm.so" ]; then
        cuvs_libs="$cuvs_libs -lrmm"
      fi
      if [ -f "$cuvs_parent/rapids_logger/lib64/librapids_logger.so" ] || \
         [ -f "$cuvs_parent/rapids_logger/lib/librapids_logger.so" ]; then
        cuvs_libs="$cuvs_libs -lrapids_logger"
      fi
    elif command -v pkg-config >/dev/null 2>&1 && pkg-config --exists cuvs 2>/dev/null; then
      cuvs_cppflags=$(pkg-config --cflags cuvs)
      cuvs_libs=$(pkg-config --libs cuvs)
    elif [ -f /usr/local/include/cuvs/neighbors/cagra.h ] && \
         { [ -f /usr/local/lib/libcuvs.so ] || [ -f /usr/local/lib/libcuvs.a ]; }; then
      cuvs_cppflags="-I/usr/local/include"
      cuvs_libs="-L/usr/local/lib -Wl,-rpath,/usr/local/lib -lcuvs"
    fi

    if [ -n "$cuvs_cppflags" ] && [ -n "$cuvs_libs" ]; then
      cuvs_objects="nn_cuvs_bridge.o nn_cuvs_impl.o"
      cppflags="$cppflags -DFAISSR_HAS_CUVS $cuvs_cppflags"
      libs="$libs $cuvs_libs"
    elif [ "$use_cuvs" = "1" ]; then
      echo "cuVS was requested (FAISSR_USE_CUVS=1 or FAISSR_REQUIRE_CUVS=1), but RAPIDS cuVS headers/library were not found." >&2
      echo "Set CUVS_HOME to a prefix containing include/cuvs and lib/libcuvs, or install a pkg-config cuvs file." >&2
      exit 1
    fi
  fi
fi

{
  echo "CXX_STD = CXX20"
  printf '%s%s\n' 'PKG_CXXFLAGS = -pthread $(SHLIB_OPENMP_CXXFLAGS)' "$extra_cxxflags"
  if [ -n "$cppflags" ]; then
    echo "PKG_CPPFLAGS = $cppflags"
  fi
  printf '%s%s\n' 'PKG_LIBS = $(SHLIB_OPENMP_CXXFLAGS) ' "$libs"
  if [ "$cuda_objects" != "nn_cuda_stub.o" ]; then
    echo "NVCC = $nvcc"
    printf "%s" "$cuda_rule"
  fi
    echo "OBJECTS = RcppExports.o embedding_utils.o nn.o $nn_metal_grid_objects nn_auto_select.o nn_fortran.o $faiss_objects $cuvs_objects nn_cuda_bridge.o $cuda_objects"
} > src/Makevars
